# ============================================================
# Ehson bot - Environment variables
# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file to version control.
# ============================================================

# Token from @BotFather
BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# IANA timezone used for date bucketing (today/month/year) and the 23:59 daily report.
TIMEZONE=Asia/Tashkent

# Telegram numeric user IDs to (re-)promote to Super Admin on every startup.
# Get your own ID from @userinfobot. Only needed to bootstrap the first Super
# Admin(s) — after that, roles are managed from within the bot itself.
SUPER_ADMIN_IDS=111111111,222222222

# Optional: a Telegram group chat id to post an anonymous "new donation
# received" announcement to after a Super Admin confirms one. Leave unset to
# skip this step entirely. Group chat ids are negative numbers — add the bot
# to the group, send any message, and check the chat.id on that update.
# PUBLIC_GROUP_CHAT_ID=-1001234567890

# --- Database (PostgreSQL) ---
POSTGRES_USER=ehson_user
POSTGRES_PASSWORD=change_this_strong_password
# 5433, not 5432: leaves 5432 free for another project's Postgres on the same
# machine. Change this if 5433 is also taken, and keep docker-compose.yml in sync.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=ehson_db
